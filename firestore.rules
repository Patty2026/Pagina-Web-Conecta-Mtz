rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function isSuperadminEmail() {
      return authEmail() == 'adminp@gmail.com';
    }

    function isBasicAdminEmail() {
      return authEmail() == 'adminb@gmail.com';
    }

    function isAdminEmail() {
      return isSuperadminEmail() || isBasicAdminEmail();
    }

    function userDocExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function userProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDocExists() && userProfile().rol != null
        ? userProfile().rol.lower()
        : '';
    }

    function isSuperadmin() {
      return isSuperadminEmail()
        || userRole().matches('.*superadmin.*');
    }

    function isAdmin() {
      return isAdminEmail()
        || userRole().matches('.*administrador.*')
        || userRole().matches('.*superadmin.*');
    }

    function isSupport() {
      return userRole().matches('.*apoyo.*');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwnAdminRecord() {
      return signedIn()
        && resource.data.correo != null
        && resource.data.correo.lower() == authEmail();
    }

    function isCreatingOwnAdminRecord() {
      return signedIn()
        && request.resource.data.correo != null
        && request.resource.data.correo.lower() == authEmail()
        && isAdminEmail();
    }

    function canSelfUpdateAdminRecord() {
      return isOwnAdminRecord()
        && request.resource.data.correo == resource.data.correo
        && request.resource.data.rol == resource.data.rol
        && request.resource.data.estado == resource.data.estado;
    }

    match /usuarios/{userId} {
      allow create: if signedIn() && (isOwner(userId) || isAdmin());
      allow read: if signedIn() && (isOwner(userId) || isAdmin());
      allow update: if signedIn() && (isOwner(userId) || isAdmin());
      allow delete: if signedIn() && isSuperadmin();
    }

    match /incidencias/{incidenciaId} {
      allow create: if signedIn() && (
        request.resource.data.idCiudadano == request.auth.uid ||
        request.resource.data.usuarioId == request.auth.uid ||
        isAdmin()
      );

      allow read: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        resource.data.usuarioId == request.auth.uid ||
        isSupport() ||
        isAdmin()
      );

      allow update: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        resource.data.usuarioId == request.auth.uid ||
        isSupport() ||
        isAdmin()
      );

      allow delete: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        resource.data.usuarioId == request.auth.uid ||
        isSuperadmin()
      );
    }

    match /contadores/{contadorId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if signedIn() && isSuperadmin();
    }

    match /estadisticas/{documentoId} {
      allow read: if signedIn() && (isAdmin() || isSupport());
      allow create, update: if signedIn() && isAdmin();
      allow delete: if signedIn() && isSuperadmin();
    }

    match /administradores/{adminId} {
      allow read: if signedIn() && isAdmin();
      allow create: if signedIn() && (isSuperadmin() || isCreatingOwnAdminRecord());
      allow update: if signedIn() && (isSuperadmin() || canSelfUpdateAdminRecord());
      allow delete: if signedIn() && isSuperadmin();
    }

    match /auditoria_admin/{logId} {
      allow read: if signedIn() && isSuperadmin();
      allow create: if signedIn() && isSuperadmin();
      allow update, delete: if false;
    }

    match /notificaciones_internas/{notificacionId} {
      allow read: if signedIn() && (isAdmin() || isSupport());
      allow create: if signedIn() && isAdmin();
      allow update, delete: if signedIn() && isSuperadmin();
    }
  }
}
