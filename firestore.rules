rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return signedIn() && request.auth.token.email != null
        ? lower(request.auth.token.email)
        : '';
    }

    function isAdminEmail() {
      return authEmail() in [
        'adminp@gmail.com',
        'adminb@gmail.com'
      ];
    }

    function userProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function userRole() {
      return signedIn() && userProfile().rol != null
        ? lower(userProfile().rol)
        : '';
    }

    function isSuperadmin() {
      return authEmail() == 'adminp@gmail.com'
        || userRole().matches('.*superadmin.*');
    }

    function isAdmin() {
      return isAdminEmail()
        || userRole().matches('.*administrador.*')
        || userRole().matches('.*superadmin.*');
    }

    function isSupport() {
      return userRole().matches('.*apoyo.*');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /usuarios/{userId} {
      allow create: if signedIn() && (isOwner(userId) || isAdmin());
      allow read: if signedIn() && (isOwner(userId) || isAdmin());
      allow update: if signedIn() && (isOwner(userId) || isAdmin());
      allow delete: if signedIn() && isAdmin();
    }

    match /incidencias/{incidenciaId} {
      allow create: if signedIn() && (
        request.resource.data.idCiudadano == request.auth.uid ||
        isAdmin()
      );

      allow read: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        isSupport() ||
        isAdmin()
      );

      allow update: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        isSupport() ||
        isAdmin()
      );

      allow delete: if signedIn() && (
        resource.data.idCiudadano == request.auth.uid ||
        isAdmin()
      );
    }

    match /contadores/{contadorId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if signedIn() && isAdmin();
    }

    match /administradores/{adminId} {
      allow read: if signedIn() && isAdmin();
      allow create, update, delete: if signedIn() && isSuperadmin();
    }

    match /auditoria_admin/{logId} {
      allow read: if signedIn() && isSuperadmin();
      allow create: if signedIn() && isSuperadmin();
      allow update, delete: if false;
    }
  }
}
